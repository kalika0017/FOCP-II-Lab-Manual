#include <iostream>
using namespace std;

int main() {
    int n, num, max;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter numbers:\n";
    cin >> max;

    for(int i = 2; i <= n; i++) {
        cin >> num;
        if(num > max)
            max = num;
    }

    cout << "Largest number = " << max;

    return 0;
}
