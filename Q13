#include <iostream>
#include <cmath>
using namespace std;

int main() {
    float a, b, c, D, r1, r2;

    cout << "Enter a, b and c: ";
    cin >> a >> b >> c;

    D = b*b - 4*a*c;

    if(D > 0) {
        r1 = (-b + sqrt(D)) / (2*a);
        r2 = (-b - sqrt(D)) / (2*a);
        cout << "Roots are real and different\n";
        cout << "Root1 = " << r1 << endl;
        cout << "Root2 = " << r2;
    }
    else if(D == 0) {
        r1 = -b / (2*a);
        cout << "Roots are equal\n";
        cout << "Root = " << r1;
    }
    else {
        cout << "Roots are imaginary";
    }

    return 0;
}
