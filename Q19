#include <iostream>
using namespace std;

int main() {
    int start, end, i, j, flag;

    cout << "Enter start and end: ";
    cin >> start >> end;

    for(i = start; i <= end; i++) {
        flag = 0;

        for(j = 2; j <= i/2; j++) {
            if(i % j == 0) {
                flag = 1;
                break;
            }
        }

        if(flag == 0 && i != 1)
            cout << i << " ";
    }

    return 0;
}
