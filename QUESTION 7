#include <iostream>
using namespace std;

double area(double r) {
    return 3.14 * r * r;
}

double area(double l, double b) {
    return l * b;
}

double area(double base, double height, int) {
    return 0.5 * base * height;
}

int main() {
    int choice;
    cin >> choice;

    if(choice == 1) {
        double r;
        cin >> r;
        cout << area(r);
    }
    else if(choice == 2) {
        double l, b;
        cin >> l >> b;
        cout << area(l,b);
    }
    else if(choice == 3) {
        double base, height;
        cin >> base >> height;
        cout << area(base,height,0);
    }

    return 0;
}
