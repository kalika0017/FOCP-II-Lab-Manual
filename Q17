#include <iostream>
using namespace std;

int main() {
    int n, temp, sum = 0, r;

    cout << "Enter number: ";
    cin >> n;

    temp = n;

    while(temp != 0) {
        r = temp % 10;
        sum = sum + (r*r*r);
        temp = temp / 10;
    }

    if(sum == n)
        cout << "Armstrong Number";
    else
        cout << "Not Armstrong Number";

    // Perfect Number check
    int i, psum = 0;
    for(i = 1; i < n; i++) {
        if(n % i == 0)
            psum += i;
    }

    if(psum == n)
        cout << "\nPerfect Number";
    else
        cout << "\nNot Perfect Number";

    return 0;
}
